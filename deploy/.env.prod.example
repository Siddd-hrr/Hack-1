# Container image source
GHCR_OWNER=your-github-username-or-org
IMAGE_TAG=latest

# Exposed ports
FRONTEND_PORT=80
GATEWAY_PORT=8080
FRONTEND_BIND_HOST=127.0.0.1
GATEWAY_BIND_HOST=0.0.0.0

# CORS
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Database
POSTGRES_USER=QPrint
POSTGRES_PASSWORD=change-me

# Redis / Kafka use defaults in compose

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Auth
# IMPORTANT: Prod JWT secret must be unique and never reused in dev/staging.
JWT_SECRET=replace-with-unique-prod-jwt-secret
JWT_ISSUER=qprint-auth
JWT_AUDIENCE=qprint-api

# Payments
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@qprint.app
